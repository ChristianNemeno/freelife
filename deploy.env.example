# =============================================================================
# deploy.env.example — copy this to deploy.env and fill in your values
#
#   cp deploy.env.example deploy.env        (Mac/Linux)
#   copy deploy.env.example deploy.env      (Windows)
#
# deploy.env is gitignored — never commit it.
# =============================================================================

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=asia-southeast1-b

# ── VM ────────────────────────────────────────────────────────────────────────
VM_NAME=freelife-vm
REUSE_VM=false

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO=https://github.com/YOUR_USERNAME/YOUR_REPO.git

# ── Secrets ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
JWT_KEY=
